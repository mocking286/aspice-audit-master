{
    "manifest_version":  3,
    "name":  "aspice-audit-master",
    "version":  "1.4.10",
    "description":  "ASPICE audit plugin for Edge with Helix ALM REST URL auto-correction, Helix DOCM evidence export/import, Codex scoring, local memory, and formal PDF export.",
    "icons":  {
                  "16":  "icons/spinning-top-16.png",
                  "32":  "icons/spinning-top-32.png",
                  "48":  "icons/spinning-top-48.png",
                  "128":  "icons/spinning-top-128.png"
              },
    "action":  {
                   "default_title":  "aspice-audit-master",
                   "default_popup":  "popup.html",
                   "default_icon":  {
                                        "16":  "icons/spinning-top-16.png",
                                        "32":  "icons/spinning-top-32.png",
                                        "48":  "icons/spinning-top-48.png",
                                        "128":  "icons/spinning-top-128.png"
                                    }
               },
    "permissions":  [
                        "tabs"
                    ],
    "host_permissions":  [
                             "http://127.0.0.1:8787/*"
                         ],
    "content_security_policy":  {
                                    "extension_pages":  "script-src \u0027self\u0027; object-src \u0027none\u0027;"
                                }
}
